    "react-dom": "19.2.5",
    "react-router": "7.14.1",
    "ua-parser-js": "^1.0.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "@rsbuild/core": "1.7.5",
    "@rsbuild/plugin-react": "1.4.6",
    "@types/jest": "^27.4.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ua-parser-js": "^0.7.36",
    "husky": "^7.0.0",
    "jest": "^27.5.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.23",
